#!/usr/bin/env bash
# atlas - operator CLI for the Atlas NVIDIA proxy
# Controls atlas-proxy.service (systemd) on http://127.0.0.1:8788
set -euo pipefail

ATLAS_PROXY_URL="${ATLAS_PROXY_URL:-http://127.0.0.1:8788}"
ATLAS_SERVICE="${ATLAS_SERVICE:-atlas-proxy.service}"

# --- color setup (TTY-aware) ---
if [[ -t 1 ]]; then
  C_GREEN=$'\033[32m'; C_CYAN=$'\033[36m'; C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'; C_BOLD=$'\033[1m'; C_RESET=$'\033[0m'
else
  C_GREEN=""; C_CYAN=""; C_YELLOW=""; C_RED=""; C_BOLD=""; C_RESET=""
fi

err()  { printf '%s%s%s\n' "$C_RED" "$*" "$C_RESET" >&2; }
info() { printf '%s%s%s\n' "$C_CYAN" "$*" "$C_RESET"; }
ok()   { printf '%s%s%s\n' "$C_GREEN" "$*" "$C_RESET"; }
warn() { printf '%s%s%s\n' "$C_YELLOW" "$*" "$C_RESET"; }

usage() {
  cat <<EOF
${C_BOLD}atlas${C_RESET} - operator CLI for the Atlas NVIDIA proxy

${C_BOLD}Usage:${C_RESET}
  atlas <command>

${C_BOLD}Commands:${C_RESET}
  start     Start the atlas-proxy systemd service
  stop      Stop the atlas-proxy systemd service
  restart   Restart the atlas-proxy systemd service
  status    Show service status + proxy /health and /stats
  logs      Follow the atlas-proxy journal, pretty-printed (Ctrl-C to exit)
            Strips host/unit prefix, ANSI, provider/failovers; recolors
            status (200 green/4xx orange/5xx red), total (<30s green/
            30-120s orange/>120s red), tokens (fixed cyan). Raw logs stay
            plain text — colour is viewer-side only.
            Pass extra journalctl flags for a one-shot query:
              atlas logs -n 100            last 100 lines
              atlas logs --since '10 min ago'
              atlas logs --raw             vanilla journalctl (no transform)
              atlas logs -o json | jq .    structured (raw passthrough)
  tokens    Clean token/usage summary since last restart
  tests     Run the pytest regression suite (no root needed)
            Verbose + colored by default: one line per test, green PASSED /
            red FAILED, so you see exactly what ran and what broke.
            Extra args pass through to pytest:
              atlas tests                            whole suite, verbose
              atlas tests -q                         quiet (dots)
              atlas tests tests/test_key_store.py    one file
              atlas tests -k cooldown                by keyword
              atlas tests --tb=long                  full tracebacks
  -h, --help, (none)   Show this help

${C_BOLD}Environment:${C_RESET}
  ATLAS_PROXY_URL   Proxy base URL (default: http://127.0.0.1:8788)
  ATLAS_SERVICE      systemd unit name (default: atlas-proxy.service)
EOF
}

require_root() {
  if [[ $EUID -ne 0 ]]; then
    err "must run as root (try: sudo atlas $1)"
    return 1
  fi
}

require_systemctl() {
  if ! command -v systemctl >/dev/null 2>&1; then
    err "systemctl not found - systemd not available on this host"
    return 1
  fi
}

do_service() {
  local action="$1"
  require_systemctl || return 1
  require_root "$action" || return 1
  info "atlas: $action $ATLAS_SERVICE"
  if systemctl "$action" "$ATLAS_SERVICE"; then
    ok "atlas: $action done"
  else
    err "atlas: $action failed"
    return 1
  fi
}

# pretty-print JSON via python3 if available, else raw
pprint_json() {
  local body="$1"
  if command -v python3 >/dev/null 2>&1; then
    printf '%s' "$body" | python3 -m json.tool 2>/dev/null || printf '%s\n' "$body"
  else
    printf '%s\n' "$body"
  fi
}

# curl an endpoint, print a section header + pretty body; silent on connection failure
probe() {
  local label="$1" path="$2"
  printf '\n%s--- %s %s%s\n' "$C_BOLD" "$label" "$ATLAS_PROXY_URL$path" "$C_RESET"
  local body
  if body=$(curl -sS --max-time 3 -m 3 "${ATLAS_PROXY_URL}${path}" 2>/dev/null); then
    if [[ -z "$body" ]]; then
      warn "empty response from $path"
    else
      pprint_json "$body"
    fi
  else
    warn "proxy not responding on $path"
  fi
}

do_status() {
  require_systemctl || return 1

  info "atlas: systemctl status $ATLAS_SERVICE"
  # non-fatal: service may be stopped, systemctl status returns non-zero then
  systemctl status "$ATLAS_SERVICE" 2>&1 || warn "(service not active or not found)"

  probe "health" "/health"
  probe "stats"  "/stats"
  echo
}

# Pretty-printer for atlas logs. Reads journalctl -o json on stdin, emits one
# clean line per record. Strips the systemd host/unit prefix, the proxy's own
# leading HH:MM:SS timestamp, ANSI codes, and "provider=nvidia", then recolors
# three fields (TTY-aware) per the operator's palette:
#   status  — 200 green, 4xx orange, 5xx red
#   total   — green <30s, orange 30–120s, red >120s
#   tokens  — fixed cyan, never changes
# Raw log files stay plain text; colour lives only here in the viewer.
#
# NB: the script MUST run via `python3 -c` (not a heredoc) so the journalctl
# pipe stays on stdin — a `<<'PY'` heredoc steals fd 0 for the script and the
# piped data never reaches it.
_atlas_log_filter() {
  python3 -c 'import sys,json,datetime,re
RESET="\033[0m"
GREEN="\033[32m"; ORANGE="\033[33m"; RED="\033[31m"; CYAN="\033[36m"
color = sys.stdout.isatty()
def paint(c,s): return f"{c}{s}{RESET}" if color else s
def status_color(s):
    try: n=int(s)
    except ValueError: return ""
    if n==200: return GREEN
    if 400<=n<500: return ORANGE
    if n>=500: return RED
    return ""
def total_color(v):
    try: f=float(v)
    except ValueError: return ""
    if f<30: return GREEN
    if f<=120: return ORANGE
    return RED
for line in sys.stdin:
    line=line.strip()
    if not line: continue
    try: e=json.loads(line)
    except json.JSONDecodeError: print(line,flush=True); continue
    raw_ts=e.get("__REALTIME_TIMESTAMP",0)
    try: ts=datetime.datetime.fromtimestamp(int(raw_ts)/1e6).strftime("%b %d %H:%M:%S")
    except (TypeError,ValueError,OSError): ts=""
    m=e.get("MESSAGE","")
    if isinstance(m,list): m=bytes(m).decode("utf-8","replace")
    m=str(m)
    m=re.sub(r"\x1b\[[0-9;]*m","",m)
    m=re.sub(r"^\d{2}:\d{2}:\d{2}\s+","",m)
    m=m.replace(" provider=nvidia","")
    m=re.sub(r" failovers=\d+","",m)
    m=m.replace(" in_tokens="," in=").replace(" out_tokens="," out=")
    # Recolor the three target fields. Operate on the cleaned (ANSI-stripped)
    # string so a re-pipe through the viewer stays stable.
    def c_status(mm):
        c=status_color(mm.group(1))
        return f"status={paint(c,mm.group(1))}" if c else mm.group(0)
    m=re.sub(r"status=(\d+)",c_status,m)
    def c_total(mm):
        c=total_color(mm.group(1))
        return f"total={paint(c,mm.group(1))}s" if c else mm.group(0)
    m=re.sub(r"total=([0-9.]+)s",c_total,m)
    def c_tokens(mm): return f"tokens={paint(CYAN,mm.group(1))}"
    m=re.sub(r"tokens=([0-9?]+)",c_tokens,m)
    print(f"{ts} {m}" if ts else m,flush=True)'
}

do_logs() {
  require_systemctl || return 1

  # --raw: vanilla journalctl, no transform (for debugging the filter itself).
  local raw=0
  local -a jargs=()
  for a in "$@"; do
    if [[ "$a" == "--raw" ]]; then raw=1; else jargs+=("$a"); fi
  done

  # Structured consumers asking for -o json/-o cat explicitly get raw passthrough
  # so `atlas logs -o json | jq .` still works.
  local want_raw=$raw
  for a in "${jargs[@]}"; do
    [[ "$a" == "-o"* || "$a" == "--output="* ]] && want_raw=1
  done

  if (( want_raw )); then
    if [[ ${#jargs[@]} -gt 0 ]]; then
      exec journalctl -u "$ATLAS_SERVICE" --no-pager "${jargs[@]}"
    fi
    exec journalctl -u "$ATLAS_SERVICE" -f --no-pager
  fi

  # One-shot query (extra args like -n 100 / --since '10 min ago'): pretty-print.
  if [[ ${#jargs[@]} -gt 0 ]]; then
    info "atlas: journalctl $ATLAS_SERVICE ${jargs[*]}"
    journalctl -u "$ATLAS_SERVICE" --no-pager -o json "${jargs[@]}" | _atlas_log_filter
    return
  fi

  # Default: follow live, pretty-printed.
  info "atlas: following journal for $ATLAS_SERVICE (Ctrl-C to exit)"
  journalctl -u "$ATLAS_SERVICE" -f --no-pager -o json | _atlas_log_filter
}

do_tokens() {
  # Resolve the atlas project dir from the CLI symlink so this works regardless
  # of cwd. The symlink at /usr/local/bin/atlas -> .../atlas/bin/atlas resolves
  # to the real script, and two dirname's climb to the project root. No hardcoded
  # fallback — if the venv isn't there, say so instead of guessing a wrong path.
  local cli_self proj_dir
  cli_self="$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || echo "$0")"
  proj_dir="$(dirname "$(dirname "$cli_self")")"
  if [[ ! -x "$proj_dir/.venv/bin/python" ]]; then
    err "atlas venv not found at $proj_dir/.venv (re-run setup/install.sh)"
    return 1
  fi
  # Run from the project dir so `proxy.token_tracker` resolves on sys.path.
  (cd "$proj_dir" && ./.venv/bin/python -m proxy.token_tracker)
}

# Recolorizer for `atlas tests`. Reads pytest -v on stdin, paints each test
# line by outcome so a wall of green lets a red failure jump out, and bolds the
# final summary line. Tracebacks, warnings, and the "=====" separators pass
# through untouched so failures stay readable. TTY-aware: no color when piped.
#
# NB: run via `python3 -c` (not a heredoc) so the pytest pipe stays on stdin —
# a `<<'PY'` heredoc steals fd 0 and the data never reaches the script.
_atlas_test_color() {
  python3 -c 'import sys,re
RESET="\033[0m"; BOLD="\033[1m"
GREEN="\033[32m"; RED="\033[31m"; CYAN="\033[36m"; YELLOW="\033[33m"
DIM="\033[2m"
color = sys.stdout.isatty()
# pytest -v lines look like:
#   tests/test_x.py::TestClass::test_name PASSED [ 12%]
# outcome is the token before the [ pct ] bracket.
outcome_re = re.compile(r"^(.*?::\S+)\s+(PASSED|FAILED|ERROR|SKIPPED|XFAIL|XPASSED)\s*(\[.*\])?\s*$")
summary_re = re.compile(r"^(=+\s)?(\d+) passed(?:.*?(\d+) failed)?(?:.*?(\d+) error)?(?:.*?(\d+) skipped)?", re.IGNORECASE)
def paint(c,s): return f"{c}{s}{RESET}" if color else s
for line in sys.stdin:
    rstrip = line.rstrip("\n")
    m = outcome_re.match(rstrip)
    if m:
        nodeid, outcome, pct = m.group(1), m.group(2), m.group(3) or ""
        if outcome in ("PASSED","XPASSED"): oc = paint(GREEN,outcome)
        elif outcome in ("FAILED","ERROR"): oc = paint(RED,outcome)
        elif outcome == "SKIPPED": oc = paint(CYAN,outcome)
        else: oc = paint(YELLOW,outcome)
        pct_s = paint(DIM,pct) if pct else ""
        print(f"{paint(DIM,nodeid)} {oc} {pct_s}".rstrip(), flush=True)
        continue
    sm = summary_re.match(rstrip)
    # Only color the standalone "N passed..." final summary, not the header line.
    if sm and rstrip and not rstrip.startswith("=") and "passed" in rstrip:
        parts = []
        if sm.group(2): parts.append(paint(GREEN,f"{sm.group(2)} passed"))
        if sm.group(3): parts.append(paint(RED,f"{sm.group(3)} failed"))
        if sm.group(4): parts.append(paint(RED,f"{sm.group(4)} error"))
        if sm.group(5): parts.append(paint(CYAN,f"{sm.group(5)} skipped"))
        # Rebuild: leading "========" (if any) stays, then our colored counts,
        # then any trailing "in X.Ys" / warnings note.
        tail = rstrip[sm.end():]
        print(paint(BOLD, " ".join(parts) + tail), flush=True)
        continue
    print(rstrip, flush=True)'
}

do_tests() {
  # Run the pytest regression suite through the project venv. Resolves the
  # project dir from the CLI symlink (same trick as do_tokens) so `atlas tests`
  # works from any cwd, and the `proxy.*` imports in tests/conftest.py resolve
  # on sys.path. No root required — it's a pure local test run, not a service
  # action. Output is verbose by default: one line per test with its node id
  # and a colored PASSED/FAILED so you can see exactly what ran and what broke.
  # Extra args pass straight through to pytest:
  #   atlas tests                            whole suite, verbose + colored
  #   atlas tests -q                         quiet (dots) — override the default
  #   atlas tests tests/test_key_store.py    one file
  #   atlas tests -k cooldown                by keyword
  #   atlas tests --tb=long                  full tracebacks
  local cli_self proj_dir
  cli_self="$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || echo "$0")"
  proj_dir="$(dirname "$(dirname "$cli_self")")"
  if [[ ! -x "$proj_dir/.venv/bin/pytest" ]]; then
    err "atlas venv/pytest not found at $proj_dir/.venv (re-run setup/install.sh)"
    return 1
  fi
  info "atlas: running test suite in $proj_dir"

  # If the caller passed their own verbosity flag, respect it and skip the
  # colorizer (they asked for raw pytest output). Otherwise default to -v
  # --tb=short and pipe through the recolorizer for a glanceable pass/fail wall.
  local user_verbose=0
  local -a pyargs=("$@")
  for a in "${pyargs[@]}"; do
    [[ "$a" == -q || "$a" == --quiet || "$a" == -v || "$a" == --verbose || "$a" == --no-header ]] && user_verbose=1
  done

  local rc=0
  if (( user_verbose )); then
    # Caller controls output — hand args straight to pytest, no colorizer.
    (cd "$proj_dir" && ./.venv/bin/pytest "${pyargs[@]}") || rc=$?
  else
    (cd "$proj_dir" && ./.venv/bin/pytest -v --tb=short "${pyargs[@]}") | _atlas_test_color || rc=${PIPESTATUS[0]}
  fi
  echo
  if [[ $rc -eq 0 ]]; then
    ok "atlas: tests passed"
  else
    err "atlas: tests failed (exit $rc)"
  fi
  return $rc
}

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        start)   do_service start ;;
        stop)    do_service stop ;;
        restart) do_service restart ;;
        status)  do_status ;;
        logs)    do_logs "$@" ;;
        tokens)  do_tokens ;;
        tests)   do_tests "$@" ;;
        -h|--help|"") usage ;;
        *)
            err "unknown command: $cmd"
            echo
            usage
            exit 2
            ;;
    esac
}

main "$@"
